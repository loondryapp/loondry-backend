// Loondry — Prisma Schema
// Assignment system (task_candidates + assignment-managed tasks)
// Database: Supabase PostgreSQL
// Run: npx prisma migrate dev --name init_assignment

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum TaskStatus {
  DA_ASSEGNARE
  IN_ATTESA
  ASSEGNATO
  A_RISCHIO
  COMPLETATO
}

enum CandidateStatus {
  PENDING
  ACCEPTED
  REJECTED
  TIMEOUT
  CANCELLED
}

// ─── Models ───────────────────────────────────────────────────────────────────

/// Task represents a cleaning/laundry job generated by a checkout.
model Task {
  id                    String    @id @default(uuid()) @db.Uuid
  apartmentId           String    @map("apartment_id") @db.Uuid
  hostId                String    @map("host_id") @db.Uuid
  laundryId             String?   @map("laundry_id") @db.Uuid

  /// Date the task should be executed (checkout day)
  date                  DateTime  @db.Date

  /// Time windows
  checkinTime           DateTime  @map("checkin_time") @db.Timestamptz
  checkoutTime          DateTime  @map("checkout_time") @db.Timestamptz

  status                TaskStatus @default(DA_ASSEGNARE)

  /// Higher = more urgent
  priority              Int       @default(0)

  /// Assigned cleaner after acceptance
  cleanerId             String?   @map("cleaner_id") @db.Uuid

  /// Index of the current candidate being asked
  currentCandidateIndex Int       @default(0) @map("current_candidate_index")

  /// Free-form notes from the host
  notes                 String?

  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  candidates            TaskCandidate[]
  logs                  TaskLog[]

  @@index([date, status])
  @@index([laundryId, date])
  @@map("assignment_tasks")
}

/// Cleaner is the pool of operators who can execute tasks.
model Cleaner {
  id             String    @id @default(uuid()) @db.Uuid
  teamMemberId   String?   @unique @map("team_member_id") @db.Uuid

  name           String
  email          String?   @unique
  phone          String?

  /// Geographic position for proximity matching
  lat            Float
  lng            Float
  radiusKm       Float     @default(10) @map("radius_km")

  /// Max tasks per day (capacity limit)
  maxTasksPerDay Int       @default(4) @map("max_tasks_per_day")

  /// Minimum buffer between tasks in minutes
  bufferMinutes  Int       @default(60) @map("buffer_minutes")

  /// JSON: [{ day: 0-6, startTime: "08:00", endTime: "18:00" }]
  availability   Json      @default("[]")

  isActive       Boolean   @default(true) @map("is_active")

  /// Acceptance rate 0-1 for scoring
  acceptanceRate Float     @default(1.0) @map("acceptance_rate")

  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  candidates     TaskCandidate[]

  @@index([isActive])
  @@map("assignment_cleaners")
}

/// TaskCandidate tracks the ordered list of cleaners tried for each task.
/// Enables full fallback chain without losing history.
model TaskCandidate {
  id          String          @id @default(uuid()) @db.Uuid
  taskId      String          @map("task_id") @db.Uuid
  cleanerId   String          @map("cleaner_id") @db.Uuid

  /// Position in the fallback chain (0 = first asked)
  orderIndex  Int             @map("order_index")

  status      CandidateStatus @default(PENDING)

  notifiedAt  DateTime?       @map("notified_at") @db.Timestamptz
  respondedAt DateTime?       @map("responded_at") @db.Timestamptz

  /// Reason for rejection (optional, set by cleaner or system)
  rejectReason String?        @map("reject_reason")

  task        Task            @relation(fields: [taskId], references: [id], onDelete: Cascade)
  cleaner     Cleaner         @relation(fields: [cleanerId], references: [id])

  @@unique([taskId, orderIndex])
  @@unique([taskId, cleanerId])
  @@index([status, notifiedAt])
  @@map("task_candidates")
}

/// TaskLog is an immutable audit trail of every state transition.
model TaskLog {
  id        String   @id @default(uuid()) @db.Uuid
  taskId    String   @map("task_id") @db.Uuid
  event     String
  payload   Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, createdAt])
  @@map("task_logs")
}
